# Runtime image consumed by goreleaser's `dockers` block.
# The `diffah` binary is supplied by the build context — see
# .goreleaser.yaml. zstd is baked in because intra-layer patching
# shells out to `zstd --patch-from`.
FROM alpine:3.23

RUN apk add --no-cache zstd ca-certificates \
 && addgroup -S diffah \
 && adduser -S -G diffah diffah

COPY diffah /usr/local/bin/diffah

USER diffah
ENTRYPOINT ["/usr/local/bin/diffah"]
